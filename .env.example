# Local dev only. Production reads these from AWS SSM /dhanam/newwealth/* (see docs/10).
NODE_ENV=development
PORT=3030

# Postgres
DATABASE_URL=postgres://newwealth:newwealth_dev@localhost:5432/dhanam_newwealth

# Auth
JWT_ACCESS_SECRET=dev_access_secret_at_least_32_chars_long_xx
JWT_REFRESH_SECRET=dev_refresh_secret_at_least_32_chars_long_x
SEED_ADMIN_EMAIL=admin@dhanam.finance
SEED_ADMIN_PASSWORD=ChangeMe_Dev_123

# CORS / web origin (dev)
WEB_ORIGIN=http://localhost:5173

# Integrations — all stubbed by default in dev
KYC_PRIMARY_PROVIDER=stub
PAYMENT_PRIMARY_PROVIDER=stub

# SSM (prod only — leave blank locally)
SSM_PARAMETERS_PATH=
SSM_REGION=ap-south-1
